PORT=4000
SQLITE_DB_PATH=./data/student_portal.db
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
OTP_EXPIRES_MINUTES=5
RESET_TOKEN_EXPIRES_MINUTES=15
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_DEV_MODE=true
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
CLIENT_URL=http://localhost:4000
COOKIE_SECRET=replace-with-another-long-random-secret
ADMIN_EMAIL=admin@studentportal.local
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_REGISTRATION_CODE=replace-with-a-private-admin-registration-code
# HTTPS_KEY_PATH=./certs/key.pem
# HTTPS_CERT_PATH=./certs/cert.pem
NODE_ENV=development
